rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidContactMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
        data.size() >= 4 && data.size() <= 6 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.email is string && data.email.size() > 0 && data.email.size() <= 255 &&
        data.message is string && data.message.size() > 0 && data.message.size() <= 2000 &&
        (!('date' in data) || (data.date is string && data.date.size() <= 20)) &&
        (!('time' in data) || (data.time is string && data.time.size() <= 20)) &&
        data.createdAt == request.time;
    }

    match /contactMessages/{messageId} {
      allow create: if isValidId(messageId) && isValidContactMessage(request.resource.data);
    }
  }
}
